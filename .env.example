# xerox-bot — Environment Variables
# Copy this file to .env and fill in your values

# Exchange
EXCHANGE=binance
API_KEY=your_api_key
API_SECRET=your_api_secret
PAPER_TRADING=true

# Risk
KILL_SWITCH=false

# Infrastructure
REDIS_URL=redis://localhost:6379
ENGINE_PORT=8000
DASHBOARD_PORT=3000

# Logging
LOG_LEVEL=INFO
